# --- Browser / Vite (optional): Supabase REST only if URL is https — not the postgres:// string ---
# VITE_SUPABASE_URL=https://uqnspgwpbkazkghrtvtq.supabase.co
# VITE_SUPABASE_ANON_KEY=your-anon-key

# --- Server-only: Postgres pooler (Session mode :6543). Never prefix with VITE_ (never ship to the client). ---
DATABASE_URL=postgresql://postgres.uqnspgwpbkazkghrtvtq:[YOUR-PASSWORD]@aws-0-us-west-2.pooler.supabase.com:6543/postgres

# Optional. In dev, the app calls /api/map-stats by default (unless VITE_DATABASE_API=false).
# Set to false if you only run `npm run dev:vite` without the Node API.
# VITE_DATABASE_API=true

# Optional overrides
# MAP_STATS_API_PORT=3456
# MAP_STATS_ROW_LIMIT=8000
# MAP_STATS_TABLE=map_stats
# MAP_INFO_TABLE=map_info
# DATABASE_SSL=true
